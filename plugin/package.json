{
  "name": "@openclaw/pilot",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin that uses Pilot Protocol as the transport. DMs your claw over an E2E-encrypted overlay — no Telegram, no webhook.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "openclaw": {
    "extensions": ["./dist/index.js"]
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "pilotprotocol": "file:../../web4/sdk/node"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "*",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "AGPL-3.0-or-later"
}
