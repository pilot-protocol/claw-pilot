{
  "id": "pilot",
  "activation": {
    "onStartup": true
  },
  "channels": ["pilot"],
  "name": "Pilot",
  "description": "Pilot Protocol channel — DM your claw over an E2E-encrypted overlay network.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channelConfigs": {
    "pilot": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "required": ["allowlist"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Friendly account name (defaults to 'default')."
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "socketPath": {
            "type": "string",
            "description": "Pilot daemon Unix socket path. Defaults to /tmp/pilot.sock.",
            "default": "/tmp/pilot.sock"
          },
          "allowlist": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "description": "Pilot addresses authorized to talk to this claw (e.g. 'N:NNNN.HHHH.LLLL').",
            "items": {
              "type": "string",
              "pattern": "^[0-9]+:[0-9A-Fa-f]{4}\\.[0-9A-Fa-f]{4}\\.[0-9A-Fa-f]{4}$"
            }
          },
          "appPort": {
            "type": "integer",
            "description": "App-layer port the plugin listens on. Pilot routes all UDP to one socket; this is a sender-side hint and is not enforced.",
            "minimum": 1,
            "maximum": 65535,
            "default": 7777
          },
          "handshakeTrustAutoApprove": {
            "type": "boolean",
            "description": "Auto-approve handshake requests from allowlisted peers.",
            "default": true
          }
        }
      }
    }
  }
}
